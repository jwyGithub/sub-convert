{
    "name": "sub-convert",
    "type": "module",
    "version": "0.0.1",
    "private": true,
    "engines": {
        "node": ">=24.0.0"
    },
    "scripts": {
        "deploy": "wrangler deploy",
        "dev": "wrangler dev",
        "start": "wrangler dev",
        "cf-typegen": "wrangler types",
        "build": "tsdown",
        "build:worker": "tsdown -F worker",
        "build:node": "tsdown -F node",
        "pages": "tsdown -F worker",
        "dev:node": "NODE_OPTIONS=--no-warnings=ExperimentalWarning tsx watch src/adapters/node.ts",
        "start:node": "NODE_OPTIONS=--no-warnings=ExperimentalWarning node dist/node/server.mjs",
        "docker:build": "docker build -t sub-convert .",
        "docker:run": "docker run --rm -p 3000:3000 -v sub-data:/data sub-convert",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix"
    },
    "dependencies": {
        "@hono/node-server": "^2.0.0",
        "cloudflare-tools": "^0.2.3",
        "hono": "^4.12.14",
        "js-yaml": "^4.1.0"
    },
    "devDependencies": {
        "@cloudflare/workers-types": "^4.20260421.1",
        "@jawyn/eslint-config": "^0.0.1",
        "@jawyn/prettier-config": "^0.0.1",
        "@jawyn/tsconfig": "^0.0.1",
        "@types/js-yaml": "^4.0.9",
        "@types/node": "^24.12.2",
        "eslint": "^10.2.1",
        "jiti": "^2.6.1",
        "prettier": "^3.8.3",
        "tsdown": "^0.21.9",
        "tsx": "^4.21.0",
        "typescript": "^5.7.2",
        "wrangler": "^4.84.0"
    }
}
